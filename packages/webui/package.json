{
  "name": "@earendil-works/pi-webui",
  "version": "0.78.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "build:server": "cd server && go build -o pi-webui-server .",
    "build:all": "npm run build && npm run build:server",
    "server": "cd server && ./pi-webui-server",
    "start": "npm run build:all && cd server && ./pi-webui-server"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "vite": "^8.0.0"
  }
}