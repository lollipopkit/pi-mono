{
  "name": "@earendil-works/pi-webui",
  "version": "0.78.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "build:server": "cd server && go build -o pi-webui-server .",
    "build:all": "npm run build && npm run build:server",
    "server": "cd server && ./pi-webui-server",
    "start": "npm run build:all && cd server && ./pi-webui-server"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "svelte": "5.56.3",
    "tailwindcss": "4.3.1",
    "vite": "8.0.16"
  }
}